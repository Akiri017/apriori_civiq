<configuration>
	<input>
	<net-file value="final_map.net.xml"/>
	<route-files value="trips_low.xml"/>
	</input>

	<processing>
		<time-to-teleport value="300"/>
		<ignore-junction-blocker value="1"/>
		<duration-log.statistics value="true"/>
	</processing>

	<time>
		<begin value="0"/>
		<end value="3600"/>
	</time>
	
	<output>
		<tripinfo-output value="data\data_selfish_low_tripinfo.xml"/>
        	<summary-output value="data\data_selfish_low_summary.xml"/>
        	<statistic-output value="data\data_selfish_low_stats.xml"/>
	</output>

</configuration>